# Path to the quantized TinyLlama GGUF model
MODEL_PATH=models/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf

# URL to download the model from if not present locally
MODEL_URL=https://huggingface.co/TheBloke/TinyLlama-1.1B-Chat-v1.0-GGUF/resolve/main/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf

# Path to the Tesseract executable (Required on Windows if not in system PATH)
# Example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Database configurations
DATABASE_PATH=database/contacts.db

# Storage directories
UPLOADS_DIR=uploads/
CACHE_DIR=cache/
LOG_DIR=logs/

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
